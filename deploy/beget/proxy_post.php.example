<?php
// Copy to proxy_post.php (gitignored), set PROXY_SECRET, upload to Beget.
// Request: POST JSON + header X-Proxy-Secret
//   { "url": "https://example.com/path", "method": "GET", "headers": {}, "body": "" }

define('PROXY_SECRET', '__PROXY_SECRET__');

header('Content-Type: application/json; charset=utf-8');

if (PROXY_SECRET === '' || PROXY_SECRET === '__PROXY_SECRET__') {
    http_response_code(503);
    echo json_encode(array('error' => 'proxy secret not configured'));
    exit;
}

$clientSecret = isset($_SERVER['HTTP_X_PROXY_SECRET']) ? $_SERVER['HTTP_X_PROXY_SECRET'] : '';
if ($clientSecret === '' || !hash_equals(PROXY_SECRET, $clientSecret)) {
    http_response_code(401);
    echo json_encode(array('error' => 'unauthorized'));
    exit;
}

$raw = file_get_contents('php://input');
$data = json_decode($raw, true);
if (!is_array($data) || empty($data['url'])) {
    http_response_code(400);
    echo json_encode(array('error' => 'missing url'));
    exit;
}

$url = $data['url'];
$method = isset($data['method']) ? strtoupper($data['method']) : 'GET';
$body = isset($data['body']) ? $data['body'] : '';
$headers = array();
if (isset($data['headers']) && is_array($data['headers'])) {
    foreach ($data['headers'] as $name => $value) {
        $headers[] = $name . ': ' . $value;
    }
}

$ch = curl_init();
curl_setopt($ch, CURLOPT_URL, $url);
curl_setopt($ch, CURLOPT_CUSTOMREQUEST, $method);
curl_setopt($ch, CURLOPT_HTTPHEADER, $headers);
curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
curl_setopt($ch, CURLOPT_ENCODING, '');
curl_setopt($ch, CURLOPT_TIMEOUT, 90);
curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
if ($method !== 'GET' && $method !== 'HEAD' && $body !== '') {
    curl_setopt($ch, CURLOPT_POSTFIELDS, $body);
}

$response = curl_exec($ch);
$code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
$ctype = curl_getinfo($ch, CURLINFO_CONTENT_TYPE);
$err = curl_error($ch);
curl_close($ch);

if ($response === false) {
    http_response_code(502);
    echo json_encode(array('error' => 'curl failed', 'detail' => $err));
    exit;
}

http_response_code($code);
if ($ctype) {
    header('Content-Type: ' . $ctype);
} else {
    header('Content-Type: application/octet-stream');
}
echo $response;
