# Production template for /etc/ikite-go/env (mode 600, root-owned).
# Copy to the server and replace all placeholder values.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ikite
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=ikite

HTTP_ADDR=127.0.0.1:8080
TZ=Asia/Jerusalem

TELEGRAM_ALERT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_AI_TOKEN=
TELEGRAM_AI_CHAT_ID=

KY_HISTORY_URL=https://your-proxy.example/wind_history.php
SURFO_LIVE_URL=https://your-proxy.example/proxy.php?url=...
BEGET_WG_STATION_URL=https://your-proxy.example/wg_station.php?id_station=%d

WG_TIMER_SCRIPT=/opt/ikite-go/deploy/add-wg-timer.sh
SETTINGS_PASS=GENERATE_A_UUID

ALERT_START_HOUR=8
ALERT_END_HOUR=17
KY_COLLECT_START_HOUR=9
KY_COLLECT_END_HOUR=19

MIGRATE=0
