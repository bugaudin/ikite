# Copy to .env and fill in real values. Never commit .env.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ikite
DB_PASSWORD=change-me
DB_NAME=ikite

HTTP_ADDR=:8080
TZ=Asia/Jerusalem

# Optional: full DSN overrides DB_* above
# DB_DSN=user:pass@tcp(127.0.0.1:3306)/ikite?parseTime=true&loc=Asia%2FJerusalem&charset=utf8mb4

# Telegram (leave token empty to disable)
TELEGRAM_ALERT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_AI_TOKEN=
TELEGRAM_AI_CHAT_ID=

# Beget generic proxy + upstream URLs (never call upstream directly)
BEGET_PROXY_URL=http://your-proxy.example/proxy_post.php
BEGET_PROXY_SECRET=
KY_HISTORY_URL=https://surfo.co.il/wp-content/themes/vibes-child/inc/weather/data/api_wind.php
SURFO_LIVE_URL=https://surfo.co.il/wp-content/themes/vibes-child/inc/weather/data/surfo_live.json
WINDOMETER_LIVE_URL=https://www.windometer.info/api/spots/live.php?slugs=pick-up-surf

# Server only: queue new Windguru timers (see deploy/install-wg-timer-queue.sh)
# WG_TIMER_QUEUE_DIR=/var/lib/ikite-go/wg-timer-queue
# WG_TIMER_SCRIPT=/opt/ikite-go/deploy/add-wg-timer.sh

# Secret GUID for /settings?pass=<uuid> (required in production)
SETTINGS_PASS=

ALERT_START_HOUR=8
ALERT_END_HOUR=17
KY_COLLECT_START_HOUR=9
KY_COLLECT_END_HOUR=19

MIGRATE=1
